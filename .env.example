# ── Clima ──
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Monterrey,MX

# ── ClickUp ──
CLICKUP_API_TOKEN=

# ── OpenClaw (enricher principal) ──
OPENCLAW_URL=http://openclaw:40291  # URL interna via red Docker compartida
OPENCLAW_TOKEN=                     # Token configurado en gateway.tokens de OpenClaw
OPENCLAW_AGENT_ID=main              # ID del agente a usar

# ── Gemini (enricher fallback) ──
GEMINI_API_KEY=

# ── TTS ──
TTS_ENGINE=elevenlabs          # elevenlabs | edge
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
EDGE_TTS_VOICE=es-MX-DaliaNeural  # Voz en espanol MX para edge-tts

# ── Chromecast (Google Home) ──
CHROMECAST_DEVICE=Google Home Sala  # Nombre exacto del dispositivo en Google Home app

# ── Servidor de audio ──
AUDIO_BASE_URL=http://srv1417253.hstgr.cloud:8123  # URL publica de la VPS
AUDIO_PORT=8123

# ── Schedule ──
WAKEUP_HOUR=7
WAKEUP_MINUTE=0
TIMEZONE=America/Monterrey

# ── General ──
LOG_LEVEL=INFO
